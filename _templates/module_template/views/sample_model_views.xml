<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View -->
    <record id="module_sample_view_form" model="ir.ui.view">
        <field name="name">module.sample.form</field>
        <field name="model">module.sample</field>
        <field name="arch" type="xml">
            <form string="Sample">
                <header>
                    <button name="action_confirm"
                            string="Confirm"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            invisible="state in ('done', 'cancelled')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,done"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="company_id"
                                   groups="base.group_multi_company"/>
                        </group>
                    </group>
                </sheet>
                <!-- <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div> -->
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="module_sample_view_list" model="ir.ui.view">
        <field name="name">module.sample.list</field>
        <field name="model">module.sample</field>
        <field name="arch" type="xml">
            <list string="Samples">
                <field name="name"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'done'"/>
                <field name="company_id"
                       groups="base.group_multi_company" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Search View -->
    <record id="module_sample_view_search" model="ir.ui.view">
        <field name="name">module.sample.search</field>
        <field name="model">module.sample</field>
        <field name="arch" type="xml">
            <search string="Search Samples">
                <field name="name"/>
                <filter name="filter_draft" string="Draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter name="filter_confirmed" string="Confirmed"
                        domain="[('state', '=', 'confirmed')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_state" string="Status"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_company" string="Company"
                            context="{'group_by': 'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="module_sample_action" model="ir.actions.act_window">
        <field name="name">Samples</field>
        <field name="res_model">module.sample</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="module_sample_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first sample record
            </p>
        </field>
    </record>

    <!-- Menu (uncomment and adjust parent as needed) -->
    <!-- <menuitem id="module_sample_menu"
              name="Samples"
              action="module_sample_action"
              parent="TODO_parent_menu"
              sequence="10"/> -->
</odoo>
